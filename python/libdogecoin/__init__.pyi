def w_sign_transaction_ex(tx_index: int, script_pubkey: _Str, privkey: _Str) -> Union[str, None]: ...
def w_sign_transaction_w_privkey_ex(tx_index: int, privkey: _Str) -> Union[str, None]: ...

# --- introspection ---------------------------------------------------------
def available() -> list[str]: ...

# ---------------------------------------------------------------------------
# Tier 3 object API (present when _HAS_TIER3 is True)
# ---------------------------------------------------------------------------
_HAS_TIER3: bool

class HandleError(RuntimeError): ...
class UseAfterFreeError(HandleError): ...

class ChainParams:
    name: str
    def __init__(self, cptr: object, name: str) -> None: ...
    def __repr__(self) -> str: ...

MAINNET: ChainParams
TESTNET: ChainParams
REGTEST: ChainParams

class HDNode:
    depth: int
    fingerprint: int
    child_num: int
    chain_code: bytes
    private_key: bytes
    public_key: bytes
    closed: bool

    def __init__(self, ptr: object) -> None: ...
    @classmethod
    def new(cls) -> HDNode: ...
    @classmethod
    def from_seed(cls, seed: bytes) -> HDNode: ...
    @classmethod
    def deserialize(cls, extkey: str, chain: ChainParams) -> HDNode: ...
    def copy(self) -> HDNode: ...
    def derive_private(self, index: int) -> HDNode: ...
    def derive_public(self, index: int) -> HDNode: ...
    def fill_public_key(self) -> None: ...
    def serialize_public(self, chain: ChainParams) -> str: ...
    def serialize_private(self, chain: ChainParams) -> str: ...
    def pub_hex(self) -> str: ...
    def free(self) -> None: ...
    def __enter__(self) -> HDNode: ...
    def __exit__(self, *exc: object) -> None: ...
    def __repr__(self) -> str: ...
