def w_get_derived_hd_address(masterkey: _Str, account: int, ischange: int, addressindex: int, outprivkey: bool = ...) -> Union[str, None]: ...
def w_get_derived_hd_address_by_path(masterkey: _Str, derived_path: _Str, outprivkey: bool = ...) -> Union[str, None]: ...

