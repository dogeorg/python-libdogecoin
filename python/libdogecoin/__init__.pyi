"""Type stubs for libdogecoin.

Covers the full ``w_*`` wrapper surface and the Tier 3 object API. Functions
beyond the base address/transaction set (BIP39/44, message signing, QR, HD key
utilities) are present only when the package was built against a libdogecoin
release that exports them; calling one that is absent raises NotImplementedError
at runtime. The stubs declare them unconditionally so type-checking and
autocomplete work regardless of build.

The Tier 3 object API (``HDNode``, ``ChainParams``) is imported under
``_HAS_TIER3``; when False, those names are absent at runtime.
"""
from __future__ import annotations

from typing import Union, overload

_Str = Union[str, bytes]

# --- context ---------------------------------------------------------------
def w_context_start() -> None: ...
def w_context_stop() -> None: ...

# --- address / key ---------------------------------------------------------
@overload
def w_generate_priv_pub_key_pair(chain_code: int = ..., as_bytes: bool = ...) -> tuple[str, str]: ...
@overload
def w_generate_priv_pub_key_pair(chain_code: int, as_bytes: bool) -> tuple[bytes, bytes]: ...
@overload
def w_generate_hd_master_pub_key_pair(chain_code: int = ..., as_bytes: bool = ...) -> tuple[str, str]: ...
@overload
def w_generate_hd_master_pub_key_pair(chain_code: int, as_bytes: bool) -> tuple[bytes, bytes]: ...
def w_generate_derived_hd_pub_key(wif_privkey_master: _Str, as_bytes: bool = ...) -> Union[str, bytes]: ...
def w_verify_priv_pub_keypair(wif_privkey: _Str, p2pkh_pubkey: _Str, chain_code: int = ...) -> bool: ...
def w_verify_master_priv_pub_keypair(wif_privkey_master: _Str, p2pkh_pubkey_master: _Str, chain_code: int = ...) -> bool: ...
def w_verify_p2pkh_address(p2pkh_pubkey: _Str) -> bool: ...

# --- address / pubkey utilities (0.1.3+) -----------------------------------
def w_is_testnet_from_b58prefix(address: _Str) -> bool: ...
def w_is_mainnet_from_b58prefix(address: _Str) -> bool: ...
def w_get_address_from_pubkey(pubkey_hex: _Str, is_testnet: bool = ...) -> Union[str, None]: ...
def w_get_pubkey_from_privkey(privkey_wif: _Str, is_testnet: bool = ...) -> Union[str, None]: ...
def w_gen_privkey(is_testnet: bool = ...) -> Union[tuple[str, str], None]: ...
def w_dogecoin_address_to_pubkey_hash(p2pkh: _Str) -> Union[str, None]: ...
def w_dogecoin_private_key_wif_to_pubkey_hash(privkey_wif: _Str) -> Union[str, None]: ...
def w_dogecoin_p2pkh_address_to_pubkey_hash(p2pkh: _Str) -> Union[str, None]: ...
def w_get_addr_from_pubkey_hash(pubkey_hash: _Str, is_testnet: bool = ...) -> Union[str, None]: ...
def w_get_wif_encoded_privkey(privkey_hex: _Str, is_testnet: bool = ...) -> str: ...
def w_get_decoded_privkey_wif(privkey_wif: _Str, is_testnet: bool = ...) -> Union[str, None]: ...

# --- transaction (stateful working-tx table) -------------------------------
def w_start_transaction() -> int: ...
def w_add_utxo(tx_index: int, hex_utxo_txid: _Str, vout: int) -> int: ...
def w_add_output(tx_index: int, destination_address: _Str, amount: Union[str, int, float]) -> int: ...
def w_finalize_transaction(tx_index: int, destination_address: _Str, subtracted_fee: Union[str, int, float], out_dogeamount_for_verification: Union[str, int, float], changeaddress: _Str) -> Union[str, int]: ...
def w_get_raw_transaction(tx_index: int) -> Union[str, int]: ...
def w_clear_transaction(tx_index: int) -> None: ...
def w_sign_raw_transaction(tx_index: int, incoming_raw_tx: _Str, script_hex: _Str, sig_hash_type: int, privkey: _Str) -> Union[str, int]: ...
def w_sign_transaction(tx_index: int, script_pubkey: _Str, privkey: _Str) -> int: ...
def w_sign_transaction_w_privkey(tx_index: int, vout_index: int, privkey: _Str) -> int: ...
