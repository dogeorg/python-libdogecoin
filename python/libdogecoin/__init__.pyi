def w_get_derived_hd_address_from_mnemonic(account: int, index: int, change_level: _Str, mnemonic: _Str, passphrase: _Str = ..., chain_code: int = ...) -> Union[str, None]: ...
def w_dogecoin_verify_mnemonic(mnemonic: _Str, language: str = ..., space: str = ..., filename: Union[str, None] = ...) -> bool: ...

