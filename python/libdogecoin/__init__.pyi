def w_get_raw_transaction_ex(tx_index: int) -> Union[str, None]: ...
def w_finalize_transaction_ex(tx_index: int, destination_address: _Str, subtracted_fee: Union[str, int, float], out_dogeamount_for_verification: Union[str, int, float], changeaddress: _Str) -> Union[str, None]: ...
